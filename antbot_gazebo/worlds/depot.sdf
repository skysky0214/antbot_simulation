            <diffuse>0.65 0.65 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="pillar_sw">
      <pose>-7.44 -3.88 1.0 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.52 0.52 2.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.52 0.52 2.0</size></box></geometry>
          <material>
