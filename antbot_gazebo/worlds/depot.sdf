    <model name="pillar_se">
      <pose>7.58 -3.84 1.0 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.48 0.52 2.0</size></box></geometry>
        </collision>
        <visual name="visual">
