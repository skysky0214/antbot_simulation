    </model>

    <model name="shelf_n4">
      <pose>8.68 -2.30 0.75 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.48 1.28 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.48 1.28 1.5</size></box></geometry>
          <material>
            <ambient>0.55 0.45 0.30 1</ambient>
            <diffuse>0.55 0.45 0.30 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="shelf_n5">
      <pose>11.44 -2.30 0.75 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.40 1.28 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.40 1.28 1.5</size></box></geometry>
          <material>
            <ambient>0.55 0.45 0.30 1</ambient>
            <diffuse>0.55 0.45 0.30 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Connector between shelf rows -->
    <model name="shelf_connector">
      <pose>4.82 -2.12 0.75 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.40 0.84 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.40 0.84 1.5</size></box></geometry>
          <material>
            <ambient>0.55 0.45 0.30 1</ambient>
            <diffuse>0.55 0.45 0.30 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Structure in upper-left area (y ≈ 4.0) -->
    <model name="structure_upper">
      <pose>-1.14 4.00 0.75 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.92 1.56 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.92 1.56 1.5</size></box></geometry>
          <material>
            <ambient>0.6 0.5 0.35 1</ambient>
            <diffuse>0.6 0.5 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="structure_upper2">
      <pose>-1.64 4.64 0.75 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.52 0.76 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.52 0.76 1.5</size></box></geometry>
          <material>
            <ambient>0.6 0.5 0.35 1</ambient>
            <diffuse>0.6 0.5 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- East-side structure -->
    <model name="structure_east">
      <pose>13.14 3.36 0.75 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.36 0.36 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.36 0.36 1.5</size></box></geometry>
          <material>
            <ambient>0.6 0.5 0.35 1</ambient>
            <diffuse>0.6 0.5 0.35 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Bench between shelf rows -->
    <model name="bench_mid">
      <pose>0.08 -5.78 0.25 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.92 0.24 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.92 0.24 0.5</size></box></geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Support pillars -->
    <model name="pillar_nw">
      <pose>-7.48 3.62 1.0 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.52 0.56 2.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.52 0.56 2.0</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.65 1</ambient>
            <diffuse>0.65 0.65 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="pillar_ne">
      <pose>7.52 3.66 1.0 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.60 0.48 2.0</size></box></geometry>
        </collision>
